# API
EVUKB_HOST=0.0.0.0
EVUKB_API_PORT=4201
EVUKB_WEB_ORIGIN=http://localhost:4200
EVUKB_LOG_LEVEL=info
EVUKB_API_PROXY_TARGET=http://localhost:4201

# Storage
EVUKB_DATABASE_URL=postgres://evukb:evukb@localhost:5432/evukb
EVUKB_BLOB_ROOT=.evukb/corpus-store
EVUKB_MAX_UPLOAD_BYTES=104857600
EVUKB_MAX_ARCHIVE_IMPORT_BYTES=524288000

# Vector backend
EVUKB_VECTOR_BACKEND=pgvector
EVUKB_QDRANT_URL=http://localhost:6333

# Mount sync modes (optional)
EVUKB_ENABLE_MOUNT_AUTHORITATIVE=false
EVUKB_ENABLE_IMPORT_WRITEBACK=false
EVUKB_MOUNT_ALLOWLIST=

# Embeddings and LLM providers
EVUKB_EMBEDDING_PROVIDER=openai-compatible
EVUKB_EMBEDDING_API_KEY=
EVUKB_EMBEDDING_BASE_URL=https://api.openai.com/v1
EVUKB_EMBEDDING_MODEL=text-embedding-3-small
EVUKB_EMBEDDING_DIMENSIONS=1536
# Optional local embeddings (Ollama sidecar): see deploy/local-embed.env.example
# EVUKB_EMBEDDING_API_KEY=local
# EVUKB_EMBEDDING_BASE_URL=http://ollama:11434/v1
# EVUKB_EMBEDDING_MODEL=<model>
# EVUKB_EMBEDDING_BATCH_SIZE=1
# Max texts per /embeddings request (use 1 for strict self-hosted llama.cpp servers)
EVUKB_EMBEDDING_BATCH_SIZE=8
# Retries for transient embedding failures (503, 502, 429, 500, 504)
EVUKB_EMBEDDING_MAX_RETRIES=3
# Markdown chunking before embedding: headings | headings_subsplit | headings_subsplit_capped
EVUKB_CHUNKING_STRATEGY=headings
# Max estimated tokens per chunk when strategy is headings_subsplit_capped (default 512)
EVUKB_CHUNK_MAX_TOKENS=512
EVUKB_CHAT_API_KEY=
EVUKB_CHAT_BASE_URL=https://api.openai.com/v1
EVUKB_CHAT_MODEL=gpt-4o-mini

# Search
EVUKB_RANKING_STRATEGY=hybrid_default_v1
# Ranking plugin reload (operator API; requires kb:admin, default off)
# EVUKB_ENABLE_RANKING_PLUGIN_RELOAD=false
# EVUKB_RANKING_PLUGIN_ALLOWLIST=/opt/evukb/plugins
# Dev API registers examples/custom-ranking-strategy/src/register-dev.ts at boot (default on outside production)
# EVUKB_REGISTER_EXAMPLE_RANKING_STRATEGIES=true
# EVUKB_EXAMPLE_RANKING_STRATEGIES_MODULE=/absolute/path/to/register-dev.ts

# Auth and secrets
# Auth is fail-closed: without EVUKB_ALLOW_OPEN_AUTH=true, HTTP and MCP requests
# require credentials even outside production. Never set this in production.
EVUKB_ALLOW_OPEN_AUTH=true
EVUKB_REQUIRE_API_KEY=false
EVUKB_SECRETS_KEY=
EVUKB_MCP_DEV_TOKEN=
EVUKB_MCP_REQUIRE_TOKEN=false
# Register evu.kb.ask on MCP (default false; capable agents should use search + list_documents)
EVUKB_MCP_ENABLE_ASK=false
# Prepend indexed frontmatter summary as first chunk (requires reindex; helps Obsidian vault inventory)
EVUKB_INDEX_FRONTMATTER_SUMMARY=false
# Required (non-empty) whenever auth is enforced; mixed into API key/MCP token hashes.
EVUKB_TOKEN_PEPPER=

# Jobs
EVUKB_SYNC_SCHEDULE_CRON=*/5 * * * *
