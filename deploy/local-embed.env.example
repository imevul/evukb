# Optional local embeddings via the Ollama compose profile.
# Copy these into your repository root .env (or deploy/docker-compose.local.yml)
# after starting the sidecar:
#
#   docker compose --project-directory . -f deploy/docker-compose.dev.yml \
#     --profile local-embed up -d ollama
#
# Pull a model (replace <model> with your choice):
#
#   docker compose --project-directory . -f deploy/docker-compose.dev.yml \
#     --profile local-embed exec ollama ollama pull <model>
#
# pgvector stores vectors as vector(1536). Verify output size before indexing:
#
#   curl -sS http://localhost:11434/v1/embeddings \
#     -H "Authorization: Bearer local" \
#     -H "Content-Type: application/json" \
#     -d '{"model":"<model>","input":["test"]}' | jq '.data[0].embedding | length'
#
# When evukb-api runs inside compose, use the service hostname:
EVUKB_EMBEDDING_API_KEY=local
EVUKB_EMBEDDING_BASE_URL=http://ollama:11434/v1
EVUKB_EMBEDDING_MODEL=<model>
EVUKB_EMBEDDING_BATCH_SIZE=1
#
# When evukb-api runs on the host (not in compose), use localhost instead:
# EVUKB_EMBEDDING_BASE_URL=http://localhost:11434/v1
