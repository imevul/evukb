{
  "name": "@evu/kb-ui",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "Reusable EvuKB React UI primitives.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./theme/tokens.css": "./src/theme/tokens.css",
    "./theme/components.css": "./src/theme/components.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "pnpm -w exec vitest run packages/kb-ui/test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@uiw/react-codemirror": "^4.25.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "lucide-react": "^1.22.0",
    "marked": "^18.0.5",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@evu/kb-core": "workspace:*",
    "@evu/kb-sdk": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.2.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.9.6"
  },
  "peerDependencies": {
    "@evu/kb-core": "workspace:*",
    "@evu/kb-sdk": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.9.6"
  }
}
