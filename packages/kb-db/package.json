{
  "name": "@evu/kb-db",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "EvuKB Drizzle schema, migrations, and database helpers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./migrate": {
      "types": "./dist/migrate.d.ts",
      "default": "./dist/migrate.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    }
  },
  "files": [
    "dist",
    "src",
    "migrations",
    "drizzle.config.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "test": "pnpm -w exec vitest run packages/kb-db/test/smoke.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@evu/kb-core": "workspace:*",
    "drizzle-orm": "^0.44.5",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.10"
  }
}
